{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jk-link-backend.jkx.workers.dev/api/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
